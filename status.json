{
  // ============================================================
  // 远程控制配置文件 - 所有字段均为可选，缺失时软件使用默认值
  // 修改此文件后，用户下次启动软件时会自动生效（无需更新软件）
  // ============================================================

  // 【紧急停止开关】
  // true  = 软件启动时弹窗警告“此软件不安全”，用户可选择继续或退出
  // false = 正常启动，无警告
  // 用途：发现严重 Bug 或被反作弊盯上时，立即拉闸保护用户
  "unsafe": false,

  // 【公告板】
  // 任意字符串，会在软件启动时显示在日志中
  // 可放通知：服务器维护、新版本发布、重要提醒等
  // 留空表示无公告
  //"notice": "欢迎使用！如有问题请联系管理员",

  // 【版本控制】
  "version": {
    // 【当前最新版本号】
    // 仅作为提示，告诉用户最新版本是多少，不强制操作
    // 应与软件内部的 current_version 变量保持一致（默认 107）
    "current": 107,

    // 【最低兼容版本号】
    // 当软件内部的 current_version < minimum 时，弹窗警告“版本过旧”
    // 用户可选择继续（不推荐）或退出
    // 设为 0 表示不检查最低版本（永远不拦截）
    // 用途：发布重大更新后，强制旧版本用户更新
    "minimum": 0
  }
}